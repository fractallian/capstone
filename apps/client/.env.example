# Supabase → Connect (or Project Settings → Database)
#
# Direct host db.<ref>.supabase.co is often IPv6-only. If nslookup fails or Supabase warns “not IPv4
# compatible”, use the Session pooler URI instead (IPv4-friendly, port 5432):
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
#
# Transaction pooler (port 6543) — serverless-friendly; app uses postgres.js with prepare: false.
# DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

DATABASE_URL=""

ORIGIN="http://localhost:5173"
# Docker / production: use your public HTTPS URL and wss:// for Colyseus (often a second subdomain).
# ORIGIN="https://app.example.com"
# PUBLIC_COLYSEUS_URL="wss://realtime.example.com"
#
# ngrok (or similar): two tunnels — app (Vite 5173) and Colyseus (2567). Example:
#   ORIGIN="https://abc123.ngrok-free.app"
#   PUBLIC_COLYSEUS_URL="wss://xyz789.ngrok-free.app"
# GitHub OAuth callback: {ORIGIN}/api/auth/callback/github — restart `pnpm dev` after changing .env.

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# GitHub OAuth — https://github.com/settings/developers — new OAuth app
# Callback URL must match: {ORIGIN}/api/auth/callback/github (e.g. http://localhost:5173/api/auth/callback/github)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Realtime game server (hosted by apps/client for now)
COLYSEUS_PORT="2567"
PUBLIC_COLYSEUS_URL="ws://localhost:2567"
# For ngrok’s second tunnel, use wss:// (HTTPS tunnel host), not ws://localhost.
