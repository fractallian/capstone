{
	"name": "capstone",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"db:probe": "node scripts/db-probe.mjs",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@capstone/contracts": "workspace:*",
		"@colyseus/ws-transport": "^0.17.9",
		"@colyseus/schema": "^4.0.7",
		"@better-auth/cli": "~1.4.21",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.0",
		"better-auth": "~1.4.21",
		"colyseus": "^0.17.8",
		"colyseus.js": "^0.16.18",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"@capstone/game-logic": "workspace:*",
		"playwright": "^1.58.2",
		"postgres": "^3.4.8",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	}
}
